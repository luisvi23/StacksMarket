APP_NAME=bitcoinworld
BACKUP_ENV=prod
AWS_REGION=us-east-1
S3_BUCKET=bitcoinworld-backups-prod
S3_PREFIX=mongodb
S3_STORAGE_CLASS=STANDARD

# MongoDB source (Atlas)
MONGODB_URI=mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DATABASE=bitcoinworld

# MongoDB tools binaries (mongodump / mongorestore)
MONGO_TOOLS_BIN_DIR=

# Local temp folder on backup runner
LOCAL_TMP_DIR=./tmp

# Optional restore target (for manual restore or daily verification)
RESTORE_MONGODB_URI=
RESTORE_DATABASE=
RESTORE_DROP_BEFORE=true

# Daily restore verification (recommended to a local/staging Mongo)
VERIFY_RESTORE_ENABLED=false
VERIFY_RESTORE_MONGODB_URI=
VERIFY_RESTORE_DATABASE=backup_verify
VERIFY_RESTORE_DROP_BEFORE=true

# Behavior
KEEP_LOCAL_ARCHIVE=false
UPLOAD_MANIFEST=true
UPLOAD_LATEST_POINTER=true
LOG_LEVEL=info
