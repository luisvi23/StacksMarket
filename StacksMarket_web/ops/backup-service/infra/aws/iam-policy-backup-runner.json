{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "S3BackupWriteReadList",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:GetObject",
        "s3:HeadObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::REPLACE_BUCKET_NAME",
        "arn:aws:s3:::REPLACE_BUCKET_NAME/*"
      ]
    },
    {
      "Sid": "S3ObjectLockIfEnabled",
      "Effect": "Allow",
      "Action": [
        "s3:PutObjectRetention",
        "s3:GetObjectRetention",
        "s3:PutObjectLegalHold",
        "s3:GetObjectLegalHold"
      ],
      "Resource": "arn:aws:s3:::REPLACE_BUCKET_NAME/*"
    },
    {
      "Sid": "KmsForS3Encryption",
      "Effect": "Allow",
      "Action": [
        "kms:Encrypt",
        "kms:Decrypt",
        "kms:GenerateDataKey",
        "kms:DescribeKey"
      ],
      "Resource": "arn:aws:kms:REGION:ACCOUNT_ID:key/REPLACE_KMS_KEY_ID"
    }
  ]
}
