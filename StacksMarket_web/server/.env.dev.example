# Dev/Testnet environment variables for Render deployment
# Copy these into Render Dashboard > Service > Environment
# DO NOT commit actual values — this is just a template.

# MongoDB Atlas (free M0 cluster) — replace with your actual connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/stacksmarket-dev?retryWrites=true&w=majority

# JWT — generate a unique random string for dev (NOT the production one)
# Example: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_USE_A_RANDOM_64_BYTE_HEX_STRING

# CORS — must match the Vercel frontend URL
CLIENT_URL=https://stacksmarket-dev.vercel.app

# Server
PORT=10000
NODE_ENV=development

# Stacks Testnet
STACKS_NETWORK=testnet
CONTRACT_ADDRESS=ST1PSHE32YTEE21FGYEVTA24N681KRGSQM4VF9XZP
CONTRACT_NAME=market-factory-v21-testnet-bias

# Hiro API Key (optional, gets rate-limited without it)
# Get one at https://platform.hiro.so/
HIRO_API_KEY=

# Cloudinary (optional, for image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
