{
  "name": "stacksmarket-server",
  "version": "1.0.0",
  "description": "StacksMarket Backend API",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "populate": "node scripts/populateData.js",
    "db:clear": "node scripts/clearDatabase.js --all",
    "db:clear:keep-admin": "node scripts/clearDatabase.js --keep-admin",
    "db:clear:trades": "node scripts/clearDatabase.js --collections=trades",
    "db:clear:comments": "node scripts/clearDatabase.js --collections=comments",
    "odds:backfill": "node scripts/backfillOnChainOdds.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1006.0",
    "@aws-sdk/lib-storage": "^3.1006.0",
    "@stacks/transactions": "^7.2.0",
    "axios": "^1.11.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.29.4",
    "mongoose": "^8.0.3",
    "multer": "^1.4.5-lts.1",
    "socket.io": "^4.7.4",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
