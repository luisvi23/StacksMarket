# Dev/Testnet environment variables for Vercel deployment
# Copy these into Vercel Dashboard > Project Settings > Environment Variables
# DO NOT commit actual values — this is just a template.

# Backend API (replace with your Render deployment URL)
REACT_APP_API_URL=https://stacksmarket-api-dev.onrender.com
REACT_APP_SOCKET_URL=https://stacksmarket-api-dev.onrender.com

# Testnet
REACT_APP_STACKS_NETWORK=testnet
REACT_APP_CONTRACT_ADDRESS=ST1PSHE32YTEE21FGYEVTA24N681KRGSQM4VF9XZP
REACT_APP_CONTRACT_NAME=market-factory-v21-testnet-bias

# WalletConnect (puede reutilizarse el de producción)
REACT_APP_WALLETCONNECT_PROJECT_ID=ea99b8504109ea3a4e0f746f6ada8ba9

# Connect / Wallets (mismos valores que .env.production)
REACT_APP_CONNECT_DEBUG=false
REACT_APP_MOBILE_CONNECT_MODE=inapp-only
REACT_APP_MOBILE_APP_CHOOSER=true
REACT_APP_MOBILE_PREFERRED_WALLET=xverse
REACT_APP_XVERSE_BROWSER_DEEPLINK=xverse://browser?url={url}
REACT_APP_LEATHER_BROWSER_DEEPLINK=leather://browser?url={url}
REACT_APP_LEATHER_BROWSER_DEEPLINKS=leather://browser?url={url},leatherwallet://browser?url={url},leather://dapp?url={url},leatherwallet://dapp?url={url}
REACT_APP_LEATHER_ENABLE_STORE_FALLBACK=false
REACT_APP_WC_XVERSE_ID=2a87d74ae02e10bdd1f51f7ce6c4e1cc53cd5f2c0b6b5ad0d7b3007d2b13de7b
REACT_APP_WC_LEATHER_ID=483afe1df1df63daf313109971ff3ef8356ddf1cc4e45877d205eee0b7893a13
REACT_APP_LEATHER_MOBILE_LINK=leather://
REACT_APP_LEATHER_APP_STORE=https://apps.apple.com/es/app/leather-bitcoin-defi-wallet/id6499127775?l=en-GB
REACT_APP_LEATHER_PLAY_STORE=https://play.google.com/store/apps/details?id=io.leather.mobile
REACT_APP_CONNECT_APP_NAME=Stacks Market (Dev)
REACT_APP_CONNECT_ICON_PATH=https://www.stacksmarket.app/logo192.png
